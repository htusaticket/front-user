  title: string;
  type: ChallengeType;
  instructions: string;
  deadline: string;
  status: "pending" | "completed";
  questions?: Question[];
}

const pendingChallenges: Challenge[] = [
  {
    id: 1,
    title: "Describe Your Morning Routine",
    type: "audio",
